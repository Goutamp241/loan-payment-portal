# =============================================================================
# Loan Repayment API — Environment Variables
# Copy this file to .env and fill in values from Supabase + Render
# =============================================================================

# Server
PORT=3001
NODE_ENV=development

# Supabase (Project Settings → API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT (generate: openssl rand -hex 32)
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=1h

# Frontend URL for CORS (Vercel URL in production)
FRONTEND_URL=http://localhost:5173

# reCAPTCHA — Google reCAPTCHA v2 is FREE for standard use
# Demo: SKIP_RECAPTCHA=true (checkbox placeholder, no Google account needed)
# Live: register at https://www.google.com/recaptcha/admin → v2 Checkbox
#       set RECAPTCHA_SECRET_KEY, SKIP_RECAPTCHA=false
#       and VITE_RECAPTCHA_SITE_KEY in Frontend/.env.local
SKIP_RECAPTCHA=true
RECAPTCHA_SECRET_KEY=

# AES-256-GCM shared secret (must match VITE_ENCRYPTION_SECRET in Frontend)
ENCRYPTION_SECRET=loan-repayment-portal-dev-secret-2026

# Payment — simulated 1Pay sandbox (assignment demo mode)
PAYMENT_MODE=simulated
DEMO_OTP=1562
