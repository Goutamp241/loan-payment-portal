# Frontend — copy to .env.local
VITE_API_BASE_URL=http://localhost:3001

# ── Google reCAPTCHA v2 (FREE — https://www.google.com/recaptcha/admin) ──
# 1. Register site → reCAPTCHA v2 → "I'm not a robot" Checkbox
# 2. Add domains: localhost + your Vercel URL
# 3. Paste Site Key below; add Secret Key to Backend/.env
# 4. Set Backend SKIP_RECAPTCHA=false
# Leave commented to use demo checkbox (SKIP_RECAPTCHA=true on backend)
# VITE_RECAPTCHA_SITE_KEY=your-site-key-here

# Must match ENCRYPTION_SECRET in Backend/.env
VITE_ENCRYPTION_SECRET=loan-repayment-portal-dev-secret-2026

# Shown on simulated 1Pay page (must match DEMO_OTP in Backend)
VITE_DEMO_OTP=1562
